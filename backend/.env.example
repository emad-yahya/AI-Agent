ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Real AI Engine Keys (Phase 6) ─────────────────────────────────────────────
# chatgpt-style engine → platform.openai.com → API keys
OPENAI_API_KEY=
# perplexity-style engine (Gemini + Search Grounding) + gemini-style engine
# → aistudio.google.com → Get API key (free tier)
GOOGLE_GEMINI_API_KEY=
# ──────────────────────────────────────────────────────────────────────────────

# Fallback provider for recommendations + content generation
AI_PROVIDER=openrouter
OPENROUTER_MODEL=google/gemma-4-31b-it:free
ANTHROPIC_MODEL=claude-haiku-4-5

# Scan throttling — 3 real engines × 5 prompts = 15 calls per full scan
AI_MAX_ENGINES=3
AI_MAX_PROMPTS=5
AI_CONCURRENCY=2
AI_DELAY_MS=2000

# Auto-scheduling (cron syntax, UTC timezone)
SCAN_SCHEDULE_ENABLED=false
SCAN_CRON_SCHEDULE=0 0 * * *

# HTTP rate limiting on POST /api/scans (per IP)
THROTTLE_TTL_MS=60000
THROTTLE_SCAN_LIMIT=5

# CORS — set to your production frontend URL before deploying
FRONTEND_URL=http://localhost:5173

# API key auth — leave empty to disable (local dev). Set a strong secret for production.
API_KEY=

# SEO Module — Serper.dev (real Google results)
# Get key at: https://serper.dev — free tier: 2,500 queries
# Leave empty to disable SEO scans.
SERPER_API_KEY=
SEO_DELAY_MS=500

# Redis — BullMQ job queue (optional, recommended for production)
# Leave empty to use fire-and-forget mode (scans lost on restart)
# With Docker Compose: REDIS_URL=redis://redis:6379
# Local Redis: REDIS_URL=redis://localhost:6379
REDIS_URL=

# Email alerts — Nodemailer SMTP (optional)
# Leave empty to disable email alerts and scheduled reports
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
